# Copy to `.env` and fill in. NEVER commit your `.env`.

# Path to the nse-agent submodule (sibling directory in the super repo by default)
AGENT_DIR=../nse-agent

# Bind config
API_PORT=8443
# Comma-separated list. Add your client origins here.
TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# === Auth ===
# Required. Strong random string. Match the value clients use in their X-API-Key header.
API_AUTH_TOKEN=

# Set to 1 ONLY for local dev when no auth token is set. NEVER in production.
ALLOW_INSECURE_API_TOKEN=

# === TLS (optional, recommended) ===
# Paths to PEM cert + key. If unset, server runs HTTP.
API_SSL_CERT_FILE=
API_SSL_KEY_FILE=

# === LLM providers — same cascade as nse-agent ===
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
OLLAMA_BASE_URL=
OLLAMA_MODEL=nemotron-3-nano:4b
